# Do not set VITE_API_URL or VITE_SOCKET_URL here.
# Production builds without these variables use same-origin Nginx routes:
#   API: /api/v1
#   Socket: /socket
#
# For local development, put machine-specific values in .env.local, for example:
#   VITE_API_URL=http://192.168.88.26:4000/api/v1
#   VITE_SOCKET_URL=ws://192.168.88.26:4000/socket
