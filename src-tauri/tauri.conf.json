{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Vetra",
  "version": "0.1.0",
  "identifier": "com.vetra.dev",
  "build": {
    "beforeDevCommand": "npm run dev:desktop-web",
    "beforeBuildCommand": "npm run build:desktop-web",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Vetra",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null,
      "capabilities": [
        "default"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
