# Copy this file to .env.smoke for local release checks.
# Never commit .env.smoke or real credentials.

VETRA_SMOKE_API_URL=http://192.168.88.26:4000/api/v1
VETRA_SMOKE_SOCKET_URL=ws://192.168.88.26:4000/socket

# The client currently logs in with the username field.
# If your deployment uses an email-like username, put that value here.
VETRA_SMOKE_USER_USERNAME=
VETRA_SMOKE_USER_PASSWORD=

# Optional second account for DM smoke checks.
VETRA_SMOKE_SECOND_USER_USERNAME=
VETRA_SMOKE_SECOND_USER_PASSWORD=

# Optional compatibility aliases if your local notes already use EMAIL names.
VETRA_SMOKE_USER_EMAIL=
VETRA_SMOKE_SECOND_USER_EMAIL=

# Default mode is read-only. Set to 1 only when you intentionally want to
# send tagged smoke messages and toggle reactions through the socket layer.
VETRA_SMOKE_WRITE=0
