# Copy this file to .env.load for LAN load testing.
# Never commit .env.load or any real credentials.

VETRA_LOAD_API_URL=http://192.168.88.26:4000/api/v1
VETRA_LOAD_SOCKET_URL=ws://192.168.88.26:4000/socket

VETRA_LOAD_USERNAME=
VETRA_LOAD_PASSWORD=
VETRA_LOAD_SECOND_USERNAME=
VETRA_LOAD_SECOND_PASSWORD=

VETRA_LOAD_VUS=10
VETRA_LOAD_DURATION_SECONDS=60
VETRA_LOAD_MESSAGES_PER_SECOND=5
VETRA_LOAD_RAMP_BATCH_SIZE=25
VETRA_LOAD_RAMP_BATCH_DELAY_MS=1000
VETRA_LOAD_STARTUP_TIMEOUT_MS=15000
VETRA_LOAD_SERVER_MONITOR=0
VETRA_LOAD_SERVER_SSH=superadmin@192.168.88.26
VETRA_LOAD_SERVER_SERVICE=vetra-server.service
VETRA_LOAD_SERVER_PORT=4000
VETRA_LOAD_SERVER_SAMPLE_INTERVAL_MS=1000
VETRA_LOAD_MONITOR_SSH_TIMEOUT_MS=5000
VETRA_LOAD_MODE=connect
VETRA_LOAD_WRITE=0
VETRA_LOAD_WRITE_RESULTS=1
